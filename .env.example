# ザラバ — シークレット設定テンプレート
# このファイルを .env にコピーして値を埋める(.env はコミット禁止 / .gitignore済み)
#
# 使い方:
#   1) cp .env.example .env して値を記入
#   2) node tools/env-to-setup.js を実行 → gas/SetupLocal.gs が生成される
#   3) SetupLocal.gs をGASエディタに貼り付けて applySecrets() を1回実行
#      (スクリプトプロパティに反映される)
#   4) GASエディタ上の SetupLocal.gs を削除(ローカルの生成物も削除してよい)

# ---- 必須 ----
DISCORD_WEBHOOK_URL=
GEMINI_API_KEY=

# ---- 大量保有報告(Phase 2)に必須 ----
EDINET_API_KEY=

# ---- J-Quants(スタンダード加入済み) ----
JQUANTS_MAIL=
JQUANTS_PASSWORD=

# ---- 任意: cron-job.org で8:30固定配信する場合の合言葉(ランダム文字列) ----
CRON_TOKEN=
